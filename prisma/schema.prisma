// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth.js (NextAuth v5) required models — @auth/prisma-adapter shape ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  playsLogged        Play[]            @relation("PlaysLoggedByUser")
  playParticipations PlayParticipant[]
  ratings            Rating[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

enum Level {
  low
  medium
  high
}

model Game {
  id String @id @default(cuid())

  bggId         Int     @unique
  name          String
  yearPublished Int?
  image         String?
  thumbnail     String?

  minPlayers  Int?
  maxPlayers  Int?
  playingTime Int?
  minPlayTime Int?
  maxPlayTime Int?

  weight    Float?
  bggRating Float?
  bggRank   Int?

  skillLevel    Level?
  luckLevel     Level?
  isCooperative Boolean @default(false)

  description String? @db.Text

  categories String[]
  mechanisms String[]

  autoVibeTags       String[]
  vibeTags           String[]
  vibeTagsOverridden Boolean  @default(false)

  inLibrary    Boolean  @default(true)
  lastSyncedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plays   Play[]
  ratings Rating[]
}

model Play {
  id              String   @id @default(cuid())
  gameId          String
  playedAt        DateTime @default(now())
  loggedByUserId  String
  notes           String?  @db.Text
  durationMinutes Int?

  createdAt DateTime @default(now())

  game         Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  loggedByUser User              @relation("PlaysLoggedByUser", fields: [loggedByUserId], references: [id])
  participants PlayParticipant[]

  @@index([gameId])
  @@index([playedAt])
}

model PlayParticipant {
  id        String  @id @default(cuid())
  playId    String
  userId    String?
  guestName String?

  play Play  @relation(fields: [playId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([playId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  rating    Int
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}
